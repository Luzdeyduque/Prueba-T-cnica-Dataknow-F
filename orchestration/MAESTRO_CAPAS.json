            "type": "TridentNotebook",
            "dependsOn": [],
            "policy": {
              "timeout": "0.12:00:00",
              "retry": 0,
              "retryIntervalInSeconds": 30,
              "secureOutput": false,
              "secureInput": false
            },
            "typeProperties": {
              "notebookId": "7c253776-cffe-466d-9eb3-8b88577a70f4",
              "workspaceId": "ade8ea43-56d4-4c3c-a5ba-110969bbd4c1",
              "parameters": {
                "batch_id": {
                  "value": {
                    "value": "@concat('batch_', formatDateTime(addHours(utcNow(), -5), 'yyyyMMdd_HHmmss'))",
                    "type": "Expression"
                  },
                  "type": "string"
                }
              }
            }
          },
          {
            "name": "Capa Silver",
            "type": "TridentNotebook",
            "dependsOn": [
              {
                "activity": "Capa Bronze",
                "dependencyConditions": ["Succeeded"]
              }
            ],
            "policy": {
              "timeout": "0.12:00:00",
              "retry": 3,
              "retryIntervalInSeconds": 30,
              "secureOutput": false,
              "secureInput": false
            },
            "typeProperties": {
              "notebookId": "887e3acb-fd01-4e8f-9fe9-646601f05cd7",
              "workspaceId": "ade8ea43-56d4-4c3c-a5ba-110969bbd4c1"
            }
          },
          {
            "name": "Capa Gold",
            "type": "TridentNotebook",
            "dependsOn": [
              {
                "activity": "Capa Silver",
                "dependencyConditions": ["Succeeded"]
              }
            ],
            "policy": {
              "timeout": "0.12:00:00",
              "retry": 3,
              "retryIntervalInSeconds": 30,
