                "dependencyConditions": ["Succeeded"]
              }
            ],
            "policy": {
              "timeout": "0.12:00:00",
              "retry": 3,
              "retryIntervalInSeconds": 30,
              "secureOutput": false,
              "secureInput": false
            },
            "typeProperties": {
              "notebookId": "8ef95986-33ec-40e4-97a9-bb3ec879b1a2",
              "workspaceId": "ade8ea43-56d4-4c3c-a5ba-110969bbd4c1"
            }
          },
          {
            "name": "Log de Monitoreo",
            "type": "TridentNotebook",
            "dependsOn": [
